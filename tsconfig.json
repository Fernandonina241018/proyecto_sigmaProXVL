{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "allowJs": true,
    "checkJs": false,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "noEmit": false,
    "isolatedModules": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "*.ts",
    "*.d.ts",
    "*.js"
  ],
  "exclude": [
    "node_modules",
    "backups",
    "Red Neuronal",
    "03-control",
    "02-operadores",
    "01-tipos"
  ]
}