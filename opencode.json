{
  "$schema": "https://opencode.ai/config.json",
  "model": "groq/llama-3.3-70b-versatile",
  "small_model": "groq/llama-3.1-8b-instant",
  "provider": {
    "ollama": {
      "name": "Ollama (local - fallback)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "timeout": 120000,
        "chunkTimeout": 60000
      },
      "models": {
        "qwen2.5-coder:0.5b": {
          "name": "Qwen 2.5 Coder 0.5B (local)"
        }
      }
    },
    "groq": {
      "name": "Groq (cloud - rápido)",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1",
        "apiKey": "{file:/home/fernando/.config/opencode/groq-key}",
        "timeout": 120000,
        "chunkTimeout": 60000
      },
      "models": {
        "llama-3.3-70b-versatile": {
          "name": "Llama 3.3 70B (inteligente)"
        },
        "llama-3.1-8b-instant": {
          "name": "Llama 3.1 8B (rápido)"
        },
        "meta-llama/llama-4-scout-17b-16e-instruct": {
          "name": "Llama 4 Scout 17B (contexto largo)"
        }
      }
    },
    "deepinfra": {
      "name": "DeepInfra (cloud)",
      "options": {
        "baseURL": "https://api.deepinfra.com/v1/openai",
        "apiKey": "{file:/home/fernando/.config/opencode/deepinfra-key}",
        "timeout": 120000,
        "chunkTimeout": 60000
      },
      "models": {
        "deepseek-ai/DeepSeek-V3-0324": {
          "name": "DeepSeek V3 (excelente para código)"
        },
        "deepseek-ai/DeepSeek-V3": {
          "name": "DeepSeek V3 (potente)"
        },
        "deepseek-ai/DeepSeek-R1-Distill-Llama-70B": {
          "name": "DeepSeek R1 Distill 70B"
        },
        "meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo": {
          "name": "Llama 3.1 8B Turbo (rápido)"
        },
        "meta-llama/Llama-3.3-70B-Instruct-Turbo": {
          "name": "Llama 3.3 70B Turbo"
        },
        "deepseek-ai/DeepSeek-V4-Flash": {
          "name": "DeepSeek V4 Flash (muy rápido)"
        }
      }
    }
  },
  "command": {
    "prompt": {
      "template": "Eres un experto en ingeniería de prompts. Aplica las mejores prácticas de Anthropic (instrucciones claras y jerarquizadas, contexto suficiente, criterios de éxito, formato de salida cuando aplique, y tono adecuado).\n\nOptimiza y reescribe el siguiente prompt del usuario conservando su intención. Si falta información crítica, indícalo al final en una breve lista.\n\nPrompt a optimizar:\n$ARGUMENTS",
      "description": "Optimizar un prompt usando mejores prácticas de Anthropic y skills disponibles",
      "agent": "general",
      "context": [
        "PROYECTO: SigmaProXVL (estadísticas, ML, spreadsheets)",
        "Ruta base: /mnt/g/My Drive/SigmaProWeb/proyecto_sigmaProXVL/",
        "Brain2 — 12 directrices integradas en auto-prompt (cargadas automáticamente):",
        "  01 — Proyecto (identidad, stack, estructura)",
        "  02 — Estadísticos (config y guía)",
        "  03 — Workflow con agente (protocolo 4 pasos)",
        "  04 — Lineamientos de código (ES6+ vanilla JS)",
        "  05 — Bugs y decisiones (registro)",
        "  06 — Políticas (bloqueantes de seguridad)",
        "  07 — Contexto base (información general)",
        "  08 — Guía nuevo estadístico (checklist operativo)",
        "  09 — Plan remediación seguridad (24 hallazgos)",
        "  10 — Protocolo cambios sin romper (evitar regresiones)",
        "  11 — Constitución del Agente AI (automejora + testing)",
        "  12 — Prompt de comportamiento (técnica avanzada)",
        "Skills en .opencode/skills/ y global ~/.config/opencode/skills/",
        "Plugin auto-prompt: /prompt command con contexto completo (learning + skills + Brain2)"
      ],
      "instructions": "Optimiza el prompt del usuario. Usa skills disponibles para enriquecer contexto. Responde con XML tags, explicación de técnicas y lista de mejores prácticas."
    }
  }
}
