// ========================================
// HELPERS - GENERAR DESDE CONFIG
// ========================================

/**
 * Genera SIDEBAR_SECTIONS desde ESTADISTICOS_CONFIG
 * @returns {Object} Secciones formateadas para el sidebar
 */
function getSeccionesSidebar() {
    const secciones = {
        descriptiva: {
            icon: '📊',
            label: 'Descriptiva',
            description: 'Análisis de tendencias centrales, dispersión y forma de datos',
            options: []
        },
        hipotesis: {
            icon: '🧪',
            label: 'Hipótesis',
            description: 'Pruebas estadísticas para validar suposiciones sobre los datos',
            options: []
        },
        correlacion: {
            icon: '📈',
            label: 'Correlación',
            description: 'Medidas de asociación y dependencia entre variables',
            options: []
        },
        regresion: {
            icon: '📉',
            label: 'Regresión',
            description: 'Modelos predictivos y métricas de ajuste',
            options: []
        },
        noParametricos: {
            icon: '🔬',
            label: 'No Paramétricos',
            description: 'Tests sin distribución normal requerida para muestras pequeñas',
            options: []
        },
        multivariado: {
            icon: '🎯',
            label: 'Multivariado',
            description: 'Análisis de múltiples variables simultáneamente',
            options: []
        },
        extras: {
            icon: '✨',
            label: 'Extras',
            description: 'Técnicas avanzadas de análisis estadístico',
            options: []
        },
        especificacion: {
            icon: '📐',
            label: 'Especificación',
            description: 'Límites de cuantificación y capacidad del proceso',
            options: []
        }
    };

    Object.entries(ESTADISTICOS_CONFIG).forEach(([nombre, config]) => {
        if (secciones[config.seccion]) {
            secciones[config.seccion].options.push(nombre);
        }
    });

    // Eliminar secciones vacías
    Object.keys(secciones).forEach(key => {
        if (secciones[key].options.length === 0) {
            delete secciones[key];
        }
    });

    return secciones;
}

/**
 * Genera lista plana de todos los estadísticos implementados
 * @returns {Array} Array con nombres de todos los estadísticos
 */
function getEstadisticosList() {
    return Object.keys(ESTADISTICOS_CONFIG);
}

/**
 * Genera metadata para reportes desde ESTADISTICOS_CONFIG
 * @returns {Object} Objeto con formula, desc, icono por estadístico
 */
function getStatMetaConfig() {
    const meta = {};
    Object.entries(ESTADISTICOS_CONFIG).forEach(([nombre, config]) => {
        meta[nombre] = {
            formula: config.formula,
            desc: config.desc,
            icono: config.icono
        };
    });
    return meta;
}

/**
 * Obtiene configuración de un estadístico específico
 * @param {string} nombre - Nombre del estadístico
 * @returns {Object|null} Configuración del estadístico o null
 */
function getEstadisticoConfig(nombre) {
    return ESTADISTICOS_CONFIG[nombre] || null;
}

/**
 * Obtiene todos los estadísticos de una sección específica
 * @param {string} seccion - Nombre de la sección
 * @returns {Array} Nombres de estadísticos en esa sección
 */
function getEstadisticosPorSeccion(seccion) {
    return Object.entries(ESTADISTICOS_CONFIG)
        .filter(([_, config]) => config.seccion === seccion)
        .map(([nombre, _]) => nombre);
}

/**
 * Obtiene todos los estadísticos que tienen edaKey (para EDA automático)
 * @returns {Object} Mapeo {edaKey: nombre del estadístico}
 */
function getEstadisticosEDA() {
    const edaMap = {};
    Object.entries(ESTADISTICOS_CONFIG).forEach(([nombre, config]) => {
        if (config.edaKey) {
            edaMap[config.edaKey] = nombre;
        }
    });
    return edaMap;
}

// ========================================
// EXPORTAR PARA USO GLOBAL
// ========================================

// Asignar al window para acceso global
if (typeof window !== 'undefined') {
    window.ESTADISTICOS_CONFIG = ESTADISTICOS_CONFIG;
    window.getSeccionesSidebar = getSeccionesSidebar;
    window.getEstadisticosList = getEstadisticosList;
    window.getStatMetaConfig = getStatMetaConfig;
    window.getEstadisticoConfig = getEstadisticoConfig;
    window.getEstadisticosPorSeccion = getEstadisticosPorSeccion;
    window.getEstadisticosEDA = getEstadisticosEDA;
}