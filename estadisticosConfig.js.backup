// ========================================
// estadisticosConfig.js - CONFIGURACIÓN CENTRALIZADA DE ESTADÍSTICOS
// StatAnalyzer Pro
// ========================================
//
// Este archivo define la configuración centralizada de todos los estadísticos
// disponibles en la aplicación. Al agregar un nuevo estadístico, solo es
// necesario modificar este archivo y agregar la función de cálculo correspondiente.
//
// ESTRUCTURA DE CADA ENTRADA:
// {
//     seccion:        'descriptiva' | 'hipotesis' | 'correlacion' | 'regresion' |
//                    'noParametricos' | 'multivariado' | 'extras' | 'especificacion'
//     calcular:       Nombre de la función en EstadisticaDescriptiva.js
//     formula:        Fórmula matemática (para notas metodológicas)
//     desc:           Descripción del estadístico
//     icono:          Emoji para UI
//     minMuestra:     Tamaño mínimo de muestra requerido
//     maxMuestra:     Tamaño máximo de muestra (opcional)
//     edaKey:         Clave para EDA automático (opcional)
//     requiereDosColumnas: true si necesita 2 columnas (correlación, etc.)
// }

const ESTADISTICOS_CONFIG = {
